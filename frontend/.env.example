# ── Backend URL ───────────────────────────────────────────────────────────────
# Local dev: point directly at the FastAPI server to avoid Next.js proxy timeout.
# Production (Vercel): set to your Railway/Render service URL.
NEXT_PUBLIC_API_BASE=http://localhost:8000

# ── Auth backend ──────────────────────────────────────────────────────────────
# Base URL of the FastAPI auth endpoints. Usually the same as NEXT_PUBLIC_API_BASE.
NEXT_PUBLIC_AUTH_BACKEND=http://localhost:8000
