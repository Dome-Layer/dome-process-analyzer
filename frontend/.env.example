# ── Backend URL (proxy mode — matches production) ────────────────────────────
# Server-side env var. Next.js rewrites `/api/*` to ${BACKEND_PROXY_URL}/api/*.
# In Vercel, set this to the Railway backend URL.
BACKEND_PROXY_URL=http://localhost:8000

# ── Backend URL (direct mode — optional dev override) ────────────────────────
# Set this to call the backend directly from the browser instead of going
# through the Next.js proxy. Useful for the analysis endpoint, which can
# exceed the dev-server's ~30s proxy timeout. Leave unset in production.
# NEXT_PUBLIC_API_BASE=http://localhost:8000

# Sentry — client-side error tracking (optional in dev, recommended in production).
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
