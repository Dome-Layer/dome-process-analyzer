# ── Backend URL ───────────────────────────────────────────────────────────────
# Local dev: point directly at the FastAPI server to avoid Next.js proxy timeout.
# Production (Vercel): set to your Railway/Render service URL.
NEXT_PUBLIC_API_BASE=http://localhost:8000

# ── Site protection ───────────────────────────────────────────────────────────
# Passphrase users must enter to access the app.
# Leave unset in local dev to disable the gate entirely.
SITE_PASSPHRASE=

# ── Local dev proxy (optional) ────────────────────────────────────────────────
# Only used when NEXT_PUBLIC_API_BASE is NOT set.
# Lets you override the Next.js rewrite destination without changing next.config.mjs.
# BACKEND_PROXY_URL=http://localhost:8000
NEXT_PUBLIC_AUTH_BACKEND=
NEXT_PUBLIC_SITE_URL=
