# LLM Provider — "claude" | "azure_openai" | "ollama"
LLM_PROVIDER=claude

# Anthropic (used when LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=

# Azure OpenAI (used when LLM_PROVIDER=azure_openai)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=

# Ollama (used when LLM_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434

# Supabase — shared DOME Platform project (all tools use the same project)
# Get these from the DOME Platform project in the Supabase dashboard
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
# Set to "production" on Railway/Render
ENVIRONMENT=development
# Comma-separated. In production: https://analyzer.domelayer.com
ALLOWED_ORIGINS=http://localhost:3000
# Frontend URL used as magic link redirect target. In production: https://analyzer.domelayer.com
SITE_URL=http://localhost:3000
# Magic link callback URL. Points to the central domelayer.com auth page so all DOME tools
# share the same login flow. Override when a dedicated auth service is introduced.
AUTH_CALLBACK_URL=https://domelayer.com/auth/callback
CACHE_TTL_SECONDS=3600

# Hourly cost-cap on POST /api/v1/analysis. Defaults are sane; tune via env if
# demo traffic patterns change. The middleware burst limit (10/60s) is
# independent and applies to everyone.
ANALYSIS_HOURLY_ANON_LIMIT=3
ANALYSIS_HOURLY_AUTH_LIMIT=30
ANALYSIS_HOURLY_WINDOW_SECONDS=3600

# Optional — Redis URL for cross-replica rate limiting. If unset, the limiter
# falls back to in-process memory (single-replica only).
# REDIS_URL=redis://...
